{
  "manifest_version": 3,
  "name": "ChatGPT Fan-Out Harvester",
  "version": "0.1.0",
  "description": "Silently captures the fan-out search queries (metadata.search_model_queries) from ChatGPT conversations you run yourself, and exports to CSV.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["injected.js"],
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Fan-Out Harvester"
  }
}
